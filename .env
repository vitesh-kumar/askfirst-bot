# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: groq | openai | gemini
PROVIDER=groq

# ── API Keys (set only the key for your chosen provider) ──────────────────────
GROQ_API_KEY=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
# OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Model override (optional — defaults are set per provider) ─────────────────
# Groq default:   llama-3.3-70b-versatile
# OpenAI default: gpt-4o-mini
# Gemini default: gemini-2.0-flash
LLM_MODEL=llama-3.3-70b-versatile

# ── Universal memory window ────────────────────────────────────────────────────
# How many messages from other threads to inject as context
MEMORY_MESSAGES=10

# ── Streamlit → FastAPI URL ────────────────────────────────────────────────────
API_BASE=http://localhost:8000
